#
# Main Menu
main_menu(){
  banner
  sites_running
  log "" "INFO" "${NC}" 
  log "A) Add Site" "INFO" "${GREEN}${BOLD}"
  log "D) Delete Site." "INFO" "${GREEN}${BOLD}"
  log "R) Restore Data" "INFO" "${GREEN}${BOLD}"
  log "S) Select Site" "INFO" "${GREEN}${BOLD}"
  log "" "INFO" "${NC}" 
  log "U) Update /KIWI/corp/bin/bash_profile script from GitHub" "INFO" "${RED}${BOLD}"
  log "Z) Drop to shell NO enviroment" "INFO" "${YELLOW}${BOLD}"
  log "" "INFO" "${NC}" 
  log "X) Exit" "INFO" "${RED}""${BOLD}"
  log "" "INFO" "${NC}" 
  echo -en "${CYAN}""${BOLD}" "Default [S] : "
  #read -t 10 choice #Time out of 10 sec
  read choice
  case "$choice" in
    "A"|"a")
            log "Chose option A" "INFO" "${YELLOW}""${BOLD}"
            site_add
    ;;
    "D"|"d")
            log "Chose option D" "INFO" "${YELLOW}""${BOLD}"
            site_delete
    ;;
    "R"|"r")
            log "Chose option R" "INFO" "${YELLOW}""${BOLD}"
            data_restore
    ;;
    "S"|"s")
            log "Chose option S" "INFO" "${YELLOW}""${BOLD}"
            site_select
    ;;
    "U"|"u")
            log "Chose option U" "INFO" "${YELLOW}""${BOLD}"
            update_scripts
    ;;
    "X"|"x")
            log "Exiting..." "INFO" "${YELLOW}""${BOLD}"
            exit 0
    ;;
    "Z"|"z")
	    log "Dropping to shell..." "INFO" "${YELLOW}""${BOLD}"
	    #log "Enter name for the site : " "INFO" "${GREEN}""${BOLD}"
	    #read 
	    #export EXEC=$SiteName
	    export EXEC=continue
	    . /KIWI/corp/bin/stdprofile

    ;;
    *)
      site_select
      return 0
    ;;
  esac
}
#
# Running sites
sites_running(){
  PS3="Choose site or 0 for main menu: "
  SITES=$(ls -d $KIWIBASE/site_* | cut -b 12-)
  log "Sites that are currently running:" "INFO" "${YELLOW}""${BOLD}"
  for j in $SITES
    do
      RUNNING=$(ps -ef | grep tomcat | grep -i "$j" | cut -b 133-136)
      if [ ! "$RUNNING" = "" ];then
        log "${GREEN}${BOLD}Site ${BLUE}${BOLD}$j ${GREEN}${BOLD}is already running" "INFO" "${BLUE}""${BOLD}"
      fi
    done
  log "" "INFO" "${GREEN}""${BOLD}"
  log "Site Ports" "INFO" "${YELLOW}""${BOLD}"
  for s in $SITES
  do
    if [ -e $KIWIBASE/services/sites/"$s"/current/conf/recentparametervalues.properties ];then
      PORTS=$(cat $KIWIBASE/services/sites/"$s"/current/conf/recentparametervalues.properties|grep OFFSET|cut -d"=" -f2)
      PORTEXT="$(expr 8080 + "$PORTS") ${GREEN}${BOLD}offset ${BLUE}${BOLD}$PORTS"
      PORTJT="$(expr 30125 + "$PORTS")"
      DBTYPE=MySQL
    else
      PORTS=""
      PORTEXT=""
      if [ -f $KIWIBASE/site_$s/data_$s/XLATEP.PH ]; then
            DBPH="ISAM"
      else
            DBPH="MySQL"
      fi	
      DBTYPE=$DBPH
    fi
    MAPREV=$(readlink $REV/site_"$s" | sed "s|^${REVS}/||")
    VUEREV=$(readlink $VUESITES/"$s"/current | sed "s|.*/||")
    if [ ! -z "$PORTS" ];then
      log "${GREEN}${BOLD}Site ${BLUE}${BOLD}$s ${GREEN}${BOLD}is a ${BLUE}${BOLD}$DBTYPE ${GREEN}${BOLD}type and has a port of ${BLUE}${BOLD}$PORTEXT / $PORTJT ${GREEN}${BOLD}and MAP Rev of ${BLUE}${BOLD}$MAPREV ${GREEN}${BOLD}and MES Rev of ${BLUE}${BOLD}$VUEREV" "INFO" "${BLUE}""${BOLD}"
    else
      log "${GREEN}${BOLD}Site ${BLUE}${BOLD}$s ${GREEN}${BOLD}is a ${BLUE}${BOLD}$DBTYPE ${GREEN}${BOLD}and MAP Rev of ${BLUE}${BOLD}$MAPREV" "INFO" "${BLUE}""${BOLD}"
    fi
  done
}
#
# Update Scripts
update_scripts(){
  UPDFILE=bash_profile
  CURRENTVER=$(cat /KIWI/corp/bin/$UPDFILE |grep VERSION= | cut -d'=' -f2)
  log "Getting the most recent bash_profile script" "INFO" "${YELLOW}""${BOLD}"
  log "Downloading from GitHub"
  cd $HOME 
  UPDFILE=bash_profile
  wget https://github.com/SFLServicesLLC/Kiwiplan/blob/main/$UPDFILE
  if [ $? -ne 0 ]; then
    log "Failed to download new script." "ERROR" "${RED}""${BOLD}"
    sleep 5
    main_menu 
  else
    UPDVER=$(cat $UPDFILE |grep VERSION= | cut -d'=' -f2)
  fi
  if [ "$CURRENTVER" -lt "$UPDVER" ];then
     log "Updating script..." "INFO" "${GREEN}""${BOLD}"
     cp -f "$UPDFILE" "$KIWIBASE/corp/bin"
     if [ $? -ne 0 ]; then
        log "Failed to update script." "ERROR" "${RED}""${BOLD}"
        sleep 5
        rm -f "$UPDFILE"
        main_menu
     fi
     chmod +x "$KIWIBASE/corp/bin/$UPDFILE"
     rm -f "$UPDFILE"
     log "Script updated successfully." "INFO" "${BLUE}""${BOLD}"
  else
     log "Script does not need to be update" "INFO" "${GREEN}""${BOLD}"
     rm -f "$UPDFILE"
  fi
}
#
# File to import
file_check(){
  log "------------------------------------------------------------------------------------------" "INFO" "${YELLOW}""${BOLD}"
  log " Select the directory your tar file  is located:" "INFO" "${BLUE}""${BOLD}"
  log "------------------------------------------------------------------------------------------" "INFO" "${YELLOW}""${BOLD}"
  # 1. Prompt the user for the file path
  read -p "Enter the full path and name of the file: " ARCHIVE
  # Remove any accidental trailing or leading spaces from user input
  ARCHIVE=$(echo "$ARCHIVE" | xargs)
  # 2. Validate: Check if the input is empty
  if [ -z "$ARCHIVE" ]; then
      log "Error: No path entered, returning to main menu." "ERROR" "${RED}""${BOLD}"
      sleep 3
      main_menu
  fi
  # 3. Validate: Check if the file exists
  if [ ! -f "$ARCHIVE" ]; then
      log "Error: File '$ARCHIVE' does not exist, returning to main menu" "ERROR" "${RED}""${BOLD}"
      sleep 3
      main_menu
  fi
  # 4. Validate: Check if it actually has a .tar.gz extension
  if [[ "$ARCHIVE" != *.tar.gz ]]; then
      log "Error: The file must be a tar archive, returning to main menu" "ERROR" "${RED}""${BOLD}"
      sleep 3
      main_menu
  fi
  # 5. Extract the file name and create the target folder name
  FULL_FILENAME=$(basename "$ARCHIVE")
  FOLDER_NAME="${FULL_FILENAME%.tar.gz}"
  DEST_DIR="$HOME/$FOLDER_NAME"
  log "File validated successfully." "INFO" "${GREEN}""${BOLD}"
  log "Creating the extract folder will be: $DEST_DIR" "INFO" "${GREEN}""${BOLD}"
  # 6. Create destination directory
  mkdir -p "$DEST_DIR"
  # 7. Extract the file
  log "Extracting files, please wait..." "INFO" "${GREEN}""${BOLD}"
  if tar -xzvf "$ARCHIVE" -C "$DEST_DIR"; then
      log "Success! Files where extracted to $DEST_DIR" "INFO" "${GREEN}""${BOLD}"
  else
      log "Extraction failed." "ERROR" "${RED}""${BOLD}"
      sleep 3
      main_menu
  fi
  log "Backup the license to the "$MREVS"/LICENSE folder" "INFO" "${GREEN}""${BOLD}"
  yes | cp -f $DEST_DIR/vue/*.licence $MREVS/LICENSE
}
#
# Add a site
site_add(){
  file_check
  log "Preparing to add a site to the environment" "INFO" "${YELLOW}""${BOLD}"
  log "Enter name for the site name : " "INFO" "${GREEN}""${BOLD}"
  read NEW_SITE

  if [ -z "$NEW_SITE" ];then
    log "You have not entered a site name" "ERROR" "${RED}""${BOLD}"
    sleep 3
    main_menu
  fi
  
  if find /KIWI/ -maxdepth 1 -type d -name site_"${NEW_SITE}" | grep -q .; then
    log "The site you entered $NEW_SITE already exist" "ERROR" "${RED}""${BOLD}"
    sleep 3
    main_menu
  fi
  
  REVS=$(find /KIWI/rev/map/* -maxdepth 0 -type d| sort)
  PS3="Select MAP revision for $NEW_SITE : "
  select REV in $REVS
  do
    if [ ! -d "/KIWI/rev/site_$NEW_SITE" ]; then
      log "Creating the $REV link to the $KIWIBASE/rev/site_"$NEW_SITE"" "INFO" "${GREEN}""${BOLD}"
      ln -s "$REV" $KIWIBASE/rev/site_"$NEW_SITE"
    fi
    log "Making the directory $KIWIBASE/site_"$NEW_SITE"" "INFO" "${GREEN}""${BOLD}"
    mkdir -p $KIWIBASE/site_"$NEW_SITE"
    log "Creating the bin link" "INFO" "${GREEN}""${BOLD}"
    ln -s $KIWIBASE/rev/site_"$NEW_SITE"/bin $KIWIBASE/site_"$NEW_SITE"/bin
    log "Creating the progs link" "INFO" "${GREEN}""${BOLD}"
    ln -s $KIWIBASE/rev/site_"$NEW_SITE"/progs $KIWIBASE/site_"$NEW_SITE"/progs
    log "Creating the scp link" "INFO" "${GREEN}""${BOLD}"
    ln -s $KIWIBASE/rev/site_"$NEW_SITE"/scp $KIWIBASE/site_"$NEW_SITE"/scp
    log "Creating the sql link" "INFO" "${GREEN}""${BOLD}"
    ln -s $KIWIBASE/rev/site_"$NEW_SITE"/sql $KIWIBASE/site_"$NEW_SITE"/sql
    break
  done

  log "Adding the $KIWIBASE/site_"$NEW_SITE"/site/bin folder" "INFO" "${GREEN}""${BOLD}"
  mkdir -p $KIWIBASE/site_"$NEW_SITE"/site/bin
  log "Adding the $KIWIBASE/site_"$NEW_SITE"/site/dat folder" "INFO" "${GREEN}""${BOLD}"
  mkdir -p $KIWIBASE/site_"$NEW_SITE"/site/dat

  gen_kidds
 
  install_mysql

  log "Adding the JAVA envirnoment requirements" "INFO" "${YELLOW}""${BOLD}"
  if [ ! -d $KIWIBASE/services  ];then
      mkdir -p $KIWIBASE/services/
  fi
  cd $KIWIBASE
  if [ ! -d $KIWIBASE/java  ];then
      ln -s $KIWIBASE/services java
  fi
  mkdir -p $KIWIBASE/services/sites/"$NEW_SITE"/
  MREVS=$(find $KIWIBASE/rev/mes/* -maxdepth 0 -type d| sort)
  PS3="Select MES revision for $NEW_SITE : "
  select MREV in $MREVS
  do
    log "Making the $NEW_SITE sites current link folder" "INFO" "${BLUE}""${BOLD}"
    cd /$KIWIBASE/services/sites/"$NEW_SITE"/
    mkdir -p $(basename "$MREV")
    ln -s $(pwd)/$(basename "$MREV") current 
    mkdir -p $KIWIBASE/services/sites/"$NEW_SITE"/current/conf
    mkdir -p $KIWIBASE/services/sites/"$NEW_SITE"/current/conf/kiwiplan/roadgrids
    ln -s $KIWIBASE/services/maps/roadgrids/osm-gh $KIWIBASE/services/sites/"$NEW_SITE"/current/conf/kiwiplan/roadgrids/osm-gh
    mkdir -p $KIWIBASE/services/sites/"$NEW_SITE"/current/logs
    log "Making the $NEW_SITE web current link folder" "INFO" "${BLUE}""${BOLD}"
    mkdir -p $KIWIBASE/services/web/"$NEW_SITE"
    cd /$KIWIBASE/services/web/"$NEW_SITE"
    mkdir -p $(basename "$MREV")
    ln -s $(pwd)/$(basename "$MREV") current
    break
  done
  log "Added $NEW_SITE to the environment type $ENVTYPE" "INFO" "${BLUE}""${BOLD}"
  log "Setting the $NEW_SITE environment from $KIWIBASE/corp/bin/stdprofile" "INFO" "${YELLOW}""${BOLD}"
  export PLANTID=$NEW_SITE
  export KIWI=$KIWIBASE/site_$PLANTID
  export EXEC="continue"
  . /KIWI/corp/bin/stdprofile
  log "Now will add the MES environment for $NEW_SITE" "INFO" "${BLUE}""${BOLD}"
  cd $MREV 
  REVBASE=$(basename "$MREV")
  log "Removing any license and copying the one from the extracted file" "INFO" "${GREEN}""${BOLD}"
  rm -rf *.licence
  log "Copying the livense from the $DEST_DIR folder" "INFO" "${GREEN}""${BOLD}"
  ls $DEST_DIR/vue/*.licence
  yes | cp $DEST_DIR/vue/*.licence .
  log "This will take some time to decompress and will start the install" "INFO" "${BLUE}""${BOLD}""${FLASH}"
  tar zxvf mes_"$REVBASE".tar*
  mv -f mes_"$REVBASE"/* .
  rmdir mes_"$REVBASE"
  export KIWI=/KIWI
  ./mes-"$REVBASE".sh
  log "Running the importdata script for the $NEW_SITE environment and looking for them in $DATASETS" "INFO" "${GREEN}""${BOLD}"
  export KIWI=/KIWI/site_$NEW_SITE
  import_site
  main_menu
}
#
# Import site
import_site(){
  cd $DEST_DIR/databases
  # import the data into the database
  log "------------------------------------------------------------------------------------------" "INFO" "${YELLOW}""${BOLD}"
  log "Starting database import process..." "INFO" "${GREEN}""${BOLD}"
  PREFIX_REPLACE="$NEW_SITE"_
  # Check if there are any .sql.gz files in the current directory
  shopt -s nullglob
  files=( *.sql.gz )
  if [ ${#files[@]} -eq 0 ]; then
      log "No .sql.gz files found in the current directory." "ERROR" "${RED}""${BOLD}"
      log "Nothing will be imported you will need to use the importsqlfiles or importdumpfiles script"  "INFO" "${GREEN}""${BOLD}"
      sleep 3
      main_menu
  fi
  # Loop through all .sql.gz files
  for file in "${files[@]}"; do
      # 1. Extract the base name (everything before .sql.gz)
      # e.g., 'santa_cwr.sql.gz' -> 'santa_cwr'
      base_name="${file%.sql.gz}"
      
      # 2. Dynamically find the prefix (everything up to and including the first underscore)
      # e.g., 'santa_cwr' -> 'santa_'
      prefix_find="${base_name%%_*}-"     # Temporary placeholder step
      prefix_find="${base_name%%_*}_"     # Correctly isolates 'santa_'
      
      # 3. Replace the discovered prefix with your new prefix
      # e.g., 'santa_cwr' becomes 'santa2_cwr'
      db_name="${base_name/$prefix_find/$PREFIX_REPLACE}"
      
      log "Processing file: $file" "INFO" "${GREEN}""${BOLD}"
      log "Detected Prefix: $prefix_find" "INFO" "${GREEN}""${BOLD}"
      log "Target database: $db_name" "INFO" "${GREEN}""${BOLD}"
      
      # Create the new database if it doesn't already exist
      log "Creating database if not exists..." "INFO" "${GREEN}""${BOLD}"
      mysql -u "$MYSQL_USER" -p"$MYSQL_PWD" -e "CREATE DATABASE IF NOT EXISTS \`$db_name\`;"
      
      # Decompress and import on the fly
      log "Importing data..." "INFO" "${GREEN}""${BOLD}"
      gunzip -c "$file" | mysql -u "$MYSQL_USER" -p"$MYSQL_PWD" "$db_name"
      
      # Check if the import was successful
      if [ ${PIPESTATUS[1]} -eq 0 ]; then
          log "Successfully imported into $db_name!" "INFO" "${GREEN}""${BOLD}"
      else
          log "Failed to import into $db_name" "ERROR" "${RED}""${BOLD}"
      fi
      log "------------------------------------------------------------------------------------------" "INFO" "${YELLOW}""${BOLD}"
  done
  $VUESITES/$NEW_SITE/current/bin/upgrade.sh
}
#
# Site Delete
site_delete(){
  if ! ls $KIWIBASE/site_* >/dev/null 2>&1; then
        echo "Sites do not exist"
        sleep 2
        main_menu
  fi
  PS3="Choose site or 0 for main menu: "
  SITES=$(ls -d $KIWIBASE/site_* | cut -b 12-)
  if "$MAPDATA"/kwsql >/dev/null 2>&1; then
        CLASSIC=$(grep "DATA=" "$MAPDATA"/kwsql|cut -d"=" -f2)
  else
        CLASSIC=""
  fi
  select SITE in $SITES
  do
    if [[ -z "$SITE" ]];then
      log "Returning to the main menu" "INFO" "${YELLOW}""${BOLD}"
      banner
      main_menu
    fi
    log "Are you sure you want to delete /KIWI/site_$SITE (Y/N or 1/0)?" "INFO" "${RED}""${BOLD}"
    read choice
      case "$choice" in
      Y|y|1)
	log "Deleting the MySQL databases" "INFO" "${YELLOW}""${BOLD}"
	# Get list of databases with the specified prefix
	databases=$(mysql -u$MYSQL_USER -p$MYSQL_PWD -e "SHOW DATABASES LIKE '${SITE}_%'" | grep -v Database)
	# Loop through each database and drop it
	for db in $databases; do
	    echo "Dropping database: $db"
	    mysql -u$MYSQL_USER -p$MYSQL_PWD -e "DROP DATABASE \`$db\`"
	    if [ $? -eq 0 ]; then
	        echo "Successfully dropped $db"
	    else
	        echo "Error dropping $db"
	    fi
	done
        log "Deleting the Kiwi Site Folder" "INFO" "${YELLOW}""${BOLD}"
        rm -rf $KIWIBASE/site_"$SITE"
	log "Deleted the Kiwi Site Folder" "INFO" "${RED}""${BOLD}"
        log "Deleting the Rev Site Folder" "INFO" "${YELLOW}""${BOLD}"
        rm -f $KIWIBASE/rev/site_"$SITE"
        log "Deleted the Rev Site Folder" "INFO" "${RED}""${BOLD}"
        log "Deleting the Jave Site Folder" "INFO" "${YELLOW}""${BOLD}"
        rm -rf $KIWIBASE/services/sites/"$SITE"/
        log "Deleted the Jave Site Folder" "INFO" "${RED}""${BOLD}"
        log "Deleting the Web Folder" "INFO" "${YELLOW}""${BOLD}"
        rm -rf $KIWIBASE/services/web/"$SITE"
        log "Deleted the Web Folder" "INFO" "${RED}""${BOLD}"
      ;;
      *)
        main_menu
      ;;
      esac
    log "We deleted the /KIWI/site_$SITE" "INFO" "${YELLOW}""${BOLD}"
    sleep 3
    break
  done
  main_menu
}

data_restore() {
    log "" "INFO" "${GREEN}""${BOLD}"
  log "Sites that are available or 0 to return to main menu:" "INFO" "${YELLOW}""${BOLD}"
  select SITE in $SITES
  do
    if [[ -z "$SITE" ]];then
        main_menu
    fi
    export PLANTID=$SITE
    export KIWI=$KIWIBASE/site_$PLANTID
    export EXEC="continue"
  done
  file_check
  import_site
  main_menu
}

install_mysql() {
  local mysqldbname
  log "Adding and setting up the kwsql file and the database " "INFO" "${YELLOW}""${BOLD}"

  if [ ! -d $KIWIBASE/site_"$NEW_SITE"/data_"$NEW_SITE" ]; then
    log "Creating the $KIWIBASE/site_"$NEW_SITE"/data_"$NEW_SITE" directory" "INFO" "${GREEN}""${BOLD}" 
    mkdir -p $KIWIBASE/site_"$NEW_SITE"/data_"$NEW_SITE"
  fi

  log "Select which directory has your backup to search:" "INFO" "${BLUE}""${BOLD}" 
  log "--------------------------------" "INFO" "${BLUE}""${BOLD}" 
  PS3="Choose a folder: "
  # Create an array of subdirectories in the current folder
  select dir in */; do
      if [ -n "$dir" ]; then
          log  "Searching in: $dir" "INFO" "${GREEN}""${BOLD}"
          
          # 2. Run the search inside the selected directory
          find "$dir" -type f \( -name "*map.*" -o -name "*classic.*" \) -exec basename {} \;
          find "$dir" -type f \( -name "*map.*" -o -name "*classic.*" \) -exec basename {} \; | grep -o -E "map|classic"
          mysqldbname=`find "$dir" -type f \( -name "*map.*" -o -name "*classic.*" \) -exec basename {} \; | grep -o -E "map|classic"`
          
          break # Exit the menu after running
      else
          echo "Invalid selection. Please choose a valid number."
      fi
  done

  #mysqldbname=$(find . -type f \( -name "*map.*" -o -name "*classic.*" \) -exec basename {} \; | grep -o -E "map|classic")
  if [ -z "$mysqldbname" ]; then
    log "Cannot find the database extention for the MAP dataset" "INFO" "${BLUE}""${BOLD}"
    log "Hit 1 for "$NEW_SITE"_classic or 2 "$NEW_SITE"_map simply enter a name to use" "INFO" "${BLUE}""${BOLD}"
    echo -en "${BLUE}""${BOLD}" "Default [2] : "
    read dbchoice
      case "$choice" in
      1)
	    mysqldbname=classic
      ;;
      2)
      mysqldbname=map
      ;;
      *)
      mysqldbname="$choice"
      ;;
      esac
  fi
  log "Drop is exists and then creating new database called $NEW_SITE_$mysqldbname " "INFO" "${YELLOW}""${BOLD}"
  mysql -e "drop database $NEW_SITE_$mysqldbname"
  mysql -e "create database $NEW_SITE_$mysqldbname"
  log "Granting permissions to $NEW_SITE_$mysqldbname " "INFO" "${YELLOW}""${BOLD}"
  mysql -e "grant all on $NEW_SITE_$mysqldbname.* to '$MYSQL_USER'@'localhost' identified by '$MYSQL_PWD'"
  mysql -e "grant all on $NEW_SITE_$mysqldbname.* to '$MYSQL_USER'@'%' identified by '$MYSQL_PWD'"
  
  log "Creating the kwsql file" "INFO" "${YELLOW}""${BOLD}"
  rm -f $KIWIBASE/site_"$NEW_SITE"/data_"$NEW_SITE"/kwsql
  touch $KIWIBASE/site_"$NEW_SITE"/data_"$NEW_SITE"/kwsql
  echo "DATA=""${NEW_SITE}""_$mysqldbname" > $KIWIBASE/site_"$NEW_SITE"/data_"$NEW_SITE"/kwsql
  echo "HOST=localhost" >> $KIWIBASE/site_"$NEW_SITE"/data_"$NEW_SITE"/kwsql
  echo "INTERFACE=sql" >> $KIWIBASE/site_"$NEW_SITE"/data_"$NEW_SITE"/kwsql
  echo "USER=$MYSQL_USER" >> $KIWIBASE/site_"$NEW_SITE"/data_"$NEW_SITE"/kwsql
  echo "PASSWORD=$MYSQL_PWD" >> $KIWIBASE/site_"$NEW_SITE"/data_"$NEW_SITE"/kwsql 
  #   echo "PASSWORDX=2o5tP2P8uX4WMp4xsjVnK8DGX5uYrwBz" >> /KIWI/site_$NEW_SITE/data_$NEW_SITE/kwsql   
  echo "LOG=error" >> $KIWIBASE/site_"$NEW_SITE"/data_"$NEW_SITE"/kwsql
  echo "LOGPID=1" >> $KIWIBASE/site_"$NEW_SITE"/data_"$NEW_SITE"/kwsql
  echo "CHARSET=latin1" >> $KIWIBASE/site_"$NEW_SITE"/data_"$NEW_SITE"/kwsql

  log "Finished adding and setting up the kwsql file and the database " "INFO" "${YELLOW}""${BOLD}"
}

gen_kidds() {
  log "Adding and setting up the KIDSENV file" "INFO" "${YELLOW}""${BOLD}"
  rm -f $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  touch $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "SHELL=/bin/sh" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "TERM=vt100" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "KIDSDEBUG=4" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "KIDSLOGDIR=/tmp" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "KIDSLOGLEVEL=4" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "KIDSLOGMAX=1000000" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "#Settings can be either error or query" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "#KWSQL_LOG turns on logging for the SQL environment, It's the equivalent of the LOG line in the kwsql file." >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "#info: Only information messages are logged (such as displaying what internal options were set, etc). File: SQLINFO.pid" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "#warn: Only warnings are logged. SQLWARN.pid" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "#error: Only errors are logged. SQLERROR.pid" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "#query: All queries issued to the SQL engine are logged. SQLQUERY.pid" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "#all: (Use this with caution). Every byte of information is logged. SQLDATA.pid" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "#KWSQL_LOG=query" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "#You always get error logs regardless of the log level set." >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "#If you have info logging on, you will not see "warn", "query" or "all" in the logs." >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "#If you have warn on, you will not see query or data logs but you will see info logs." >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "#If you have error on, you will also see warn and info, but not query or data" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "#If you have query on, you will also see warn and info, but not data" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "#If you have "all" on, you see the lot." >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "MAXPROC=1000 # This allows the maximum number of concurrent KIWIPLAN processes to be set. (Default is 256)." >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "KWLOCK_TIME_LOG=15 # For locking diagnostics" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "KWLOCK_TIME_COUNT=15 # For locking diagnostics" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "KIWI_NO_CATCH_HUP=1" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "KIWI_LOCK_NOPID=1 # reduced overhead in the system writing a Process ID for every file lock" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "KIWI_LOCK_DELAY=1000" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "KWSQL_NODELAY_ON_EXIT=1 # influence the BOB performance" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "KIWISITE=$NEW_SITE" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "KIWI=/KIWI/site_$NEW_SITE" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "DATA=\$KIWI/data_$NEW_SITE" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "WORK=\$KIWI/work/$LOGNAME" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "BIN=\$KIWI/bin/" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "PROGS=\$KIWI/progs/" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "SCP=\$KIWI/scp/" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "SITEBIN=\$KIWI/site/bin" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "SITEDAT=\$KIWI/site/dat" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "SQL=\$KIWI/sql" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "KIDSLOGDIR=\$KIWI/work/$LOGNAME" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "KWSQL_COMMONDIR=\$KIWI/data_$NEW_SITE" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "LD_LIBRARY_PATH=\$PROGS" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "KWSQL_USER=$MYSQL_USER" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "KWSQL_PASS=$MYSQL_PWD" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "KIWISEA=.:\$DATA:\$SITEDAT:\$SITEBIN:\$PROGS:\$BIN:\$SCP:\$SQL"  >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  echo "PATH=\$PATH:.:\$SITEDAT:\$SITEBIN:\$CORPBIN:\$PROGS:\$BIN:\$DAT" >> $KIWIBASE/site_"$NEW_SITE"/KIDSENV
  log "Finished adding and setting up the KIDSENV file" "INFO" "${YELLOW}""${BOLD}"
}

#need to fix counter for classic and VUE here
setup_counter () {
  cd $KIWIBASE
  if [ ! -d $KIWIBASE/"$SITE_counter" ];then
        mkdir -p $KIWIBASE/"$SITE_counter"
  fi
  #ln -s $KIWIBASE/site_"$NEW_SITE"/work/mdcxmt "$SITE_counter"
}
#
# Select a site
site_select(){
  if [ ! -d $KIWIBASE/site_*  ];then
    log "Sites do not exists" "ERROR" "${RED}""${BOLD}""${FLASH}"
    sleep 5
    main_menu
  fi
  log "" "INFO" "${GREEN}""${BOLD}"
  log "Sites that are available or 0 to return to main menu:" "INFO" "${YELLOW}""${BOLD}"
  select SITE in $SITES
  do
    if [[ -z "$SITE" ]];then
        main_menu
    fi

    export PLANTID=$SITE
    export KIWI=$KIWIBASE/site_$PLANTID
    export EXEC="kiwimenu menu=support"

    # Check id kwsql file exists
    if [ -e $KIWIBASE/site_"$SITE"/data_"$SITE"/kwsql ];then
      export CLASSIC=$(grep "DATA=" $KIWIBASE/site_"$SITE"/data_"$SITE"/kwsql|cut -d"=" -f2)
      # MySQL query
      QUERY="SELECT SUBSTRING(xl_body,30,39) FROM XLATEP WHERE xl_system='GEN' AND xl_prefix='EE' OR xl_prefix='EI'"
      # Execute query and store results
      results=$(mysql -h "$DBHOST" -u "$MYSQL_USER" -p"$MYSQL_PWD" -D "$CLASSIC" -e "$QUERY" --batch --silent)
    fi

    # Check if query was successful
    if [ $? -ne 0 ]; then
      log "Error executing MySQL query" "ERROR" "${RED}""${BOLD}""${FLASH}"
      sleep 5
      main_menu
    fi

    # Read results line by line
    while IFS=$'\t' read -r -a columns; do
      if [ -n "${columns[0]}" ]; then
        mkdir -p "$(echo "${columns[0]}" | tr -d ' ')" 
        if [ $? -eq 0 ]; then
          log "Created the following folder : ${columns[0]}" "INFO" "${BLUE}""${BOLD}"
        else
          log "Failed to create folder : ${columns[0]}" "ERROR" "${RED}""${BOLD}"
        fi
      else
        log "Empty folder name in first column" "WARNING" "${YELLOW}""${BOLD}"
      fi
    done <<< "$results"

    setup_counter
    . $KIWIBASE/corp/bin/stdprofile
    break
  done
}
