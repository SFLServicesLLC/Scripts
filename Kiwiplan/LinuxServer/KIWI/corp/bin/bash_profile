  log "${BLUE}║${NC} ${YELLOW}Linux${NC}                ${BLUE}│${NC}                       ${BLUE}│${NC}              ${BLUE}║" "INFO" "${NC}"
  print_host "sfl-lin-004" "192.168.101.20" "RedHat"
  log "${BLUE}║${NC} ${YELLOW}KDG${NC}                  ${BLUE}│${NC}                       ${BLUE}│${NC}              ${BLUE}║" "INFO" "${NC}"
  print_host "sfl-kdg-001" "192.168.101.16" "Win22"
  log "${BLUE}║${NC} ${YELLOW}ESP SQL${NC}              ${BLUE}│${NC}                       ${BLUE}│${NC}              ${BLUE}║" "INFO" "${NC}"
  print_host "sfl-sql-001" "192.168.101.15" "Win22"
  log "${BLUE}║${NC} ${YELLOW}ESP/FFF/VUE${NC}          ${BLUE}│${NC}                       ${BLUE}│${NC}              ${BLUE}║" "INFO" "${NC}"
  print_host "sfl-rds-002" "192.168.101.14" "Win22"
  print_host "sfl-rds-003" "192.168.101.11" "Win22"
  print_host "sfl-rds-004" "192.168.101.12" "Win22"
  print_host "sfl-rds-005" "192.168.101.13" "Win22"
  print_host "sfl-rds-006" "192.168.101.18" "Win22"
  log "${BLUE}║${NC} ${YELLOW}VUE Only${NC}             ${BLUE}│${NC}                       ${BLUE}│${NC}              ${BLUE}║" "INFO" "${NC}"
  print_host "sfl-vue-001" "192.168.101.18" "Win25"
  log "${BLUE}╚══════════════════════╧═══════════════════════╧══════════════╝" "INFO" "${NC}"
  #
  log "" "INFO" "${GREEN}${BOLD}"
  log "Version $VERSION" "INFO" "${BLUE}${BOLD}"
  log "╔═════════════════════════════════════════╗" "INFO" "${GREEN}${BOLD}"
  log "║  Welcome to the Test/Dev Environment    ║" "INFO" "${GREEN}${BOLD}"
  log "║                                         ║" "INFO" "${GREEN}${BOLD}"
  log "║ You are in the server:                  ║" "INFO" "${GREEN}${BOLD}"
