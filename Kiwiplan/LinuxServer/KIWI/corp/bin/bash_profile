  log "${BLUE}╔══════════════════════╤═══════════════════════╤══════════════╗" "INFO" "${NC}"
  log "${BLUE}║${NC} ${BOLD}Hostname / Type${NC}      ${BLUE}│${NC} ${BOLD}IP Address${NC}            ${BLUE}│${NC} ${BOLD}Status${NC}       ${BLUE}║" "INFO" "${NC}"
  log "${BLUE}╠══════════════════════╪═══════════════════════╪══════════════╣" "INFO" "${NC}"

  # Function to print a row with status
  print_host() {
      local name="$1"
      local ip="$2"
      local type="$3"   # optional extra info like Win22

      # Ping test (1 attempt, 1 second timeout)
      if ping -c1 -W1 "$ip" &>/dev/null; then
          STATUS="${GREEN}Online${NC}"
      else
          STATUS="${RED}Offline${NC}"
      fi

      log "${BLUE}║${NC} ${GREEN}${name}${NC} ${YELLOW}${type}${NC}    ${BLUE}│${NC} ${YELLOW}${ip}${NC}        ${BLUE}│${NC} ${STATUS}       ${BLUE}║" "INFO" "${NC}"
  }
