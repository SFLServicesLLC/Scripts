  DATASETSCD=$HOME
}
#
# Define colors
RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
BLUE='\033[1;36m'
CYAN='\033[1;36m'
NC='\033[0m' # No Color
BOLD='\033[1m'
FLASH='\033[5m'
#
# Define log file
# Logging configuration
LOG_FILE="/KIWI/corp/bin/bash_profile.log"
MAX_LOG_SIZE=$((2*1024*1024)) # 2MB
LOG_DIR=$(dirname "$LOG_FILE")
#
# Ensure log directory exists
mkdir -p "$LOG_DIR"
#
# Logging function
log() {
  local message="$1"
  local level="$2" # Optional: INFO, WARNING, ERROR
  local color="$3"

  # Timestamp
  timestamp=$(date +"%Y-%m-%d %H:%M:%S")

  # Log message with level and timestamp
  echo -e "${color}${message}${NC}" | tee -a "$LOG_FILE"
  #echo -e "${color}${message}${NC}" >> "$LOG_FILE"
  echo "[${timestamp}] [${level}] ${message}" | logger
}
#
rotate_log() {
  log "Starting to log rotate" "INFO" "${GREEN}${BOLD}"
  # 1. Quick exit if file doesn't exist
  [[ -f "$LOG_FILE" ]] || return 0

  # 2. Get file size portably using 'wc -c'
  local log_size
  log_size=$(wc -c < "$LOG_FILE" 2>/dev/null | tr -d '[:space:]')

  # Fallback to stat if wc fails for some reason
  if [[ -z "$log_size" ]]; then
      log_size=$(stat -c %s "$LOG_FILE" 2>/dev/null || stat -f %z "$LOG_FILE" 2>/dev/null)
  fi

  # 3. Check if size exceeds maximum (and ensure log_size is a valid number)
  if [[ "$log_size" =~ ^[0-9]+$ ]] && (( log_size >= MAX_LOG_SIZE )); then
      local arch_new_log="${LOG_FILE}.$(date '+%Y%m%d%H%M%S').log"
      
      log "Log file size ($log_size bytes) exceeds limit ($MAX_LOG_SIZE bytes). Rotating..." "INFO" "${GREEN}${BOLD}"
      
      # 4. Atomic move and recreation
      if mv "$LOG_FILE" "$arch_new_log"; then
          touch "$LOG_FILE"
          log "Archived log to: $arch_new_log" "INFO" "${GREEN}${BOLD}"
      else
          log "Failed to rotate log file!" "ERROR" "${RED}${BOLD}"
          return 1
      fi
  fi
  log "Finished to log rotate" "INFO" "${GREEN}${BOLD}"
}
#
# Verify some of the environment variables
checkVariables() {
  if [ ! -d "$REVS" ];then
          log "$REVS does not exist" "ERROR" "${RED}${BOLD}${FLASH}"
          sleep 5
          return 1
  fi
  #
  if [ ! -d "$MREVS" ];then
          log "$MREVS does not exist" "ERROR" "${RED}${BOLD}${FLASH}"
          sleep 5
          return 1
  fi
  #
  if [ ! -d "$DATASETS" ];then
          log "$DATASETS does not exist" "ERROR" "${RED}${BOLD}${FLASH}"
          sleep 5
          return 1
  fi
}
#
# Display banner
banner(){
